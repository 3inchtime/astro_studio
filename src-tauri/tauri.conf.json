{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Astro Studio",
  "version": "0.0.23",
  "identifier": "com.astrostudio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Astro Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "decorations": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://localhost:1420; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFMENFRTMyNjY5MTc3NTgKUldSWWQ1Rm1NdTRNanJmTm5FbU56M3JmaE4zSkg2MEl5bzNZUjZLK3hSdjBDaDlLR2xQUHBqb0cK",
      "endpoints": [
        "https://github.com/3inchtime/astro_studio/releases/latest/download/latest.json"
      ]
    }
  }
}
